rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(tripId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.memberUids;
    }

    match /trips/{tripId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.memberUids;

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isSignedIn() && (
        // Existing member making normal edits (createdBy must stay the same)
        (
          request.auth.uid in resource.data.memberUids
          && request.resource.data.createdBy == resource.data.createdBy
        )
        ||
        // Non-member joining via invite code:
        // - The caller was NOT already a member
        // - New memberUids is exactly old memberUids + caller's uid only
        // Note: invite code ownership is client-enforced; tripId auto-IDs (26-char)
        // make brute-force guessing impractical for this personal-use MVP.
        (
          !(request.auth.uid in resource.data.memberUids)
          && request.resource.data.memberUids.hasAll(resource.data.memberUids)
          && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
          && request.auth.uid in request.resource.data.memberUids
          && request.resource.data.createdBy == resource.data.createdBy
        )
      );

      allow delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;

      match /{sub}/{docId} {
        allow read, write: if isMember(tripId);
      }
    }

    match /inviteCodes/{code} {
      allow get: if isSignedIn();
      allow list: if false;
      // Only members of the referenced trip can create invite codes
      allow create: if isSignedIn()
        && isMember(request.resource.data.tripId);
      allow update, delete: if false;
    }
  }
}
